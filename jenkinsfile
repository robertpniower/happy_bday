pipeline {
    agent any

    environment {
        REPO_URL = 'https://github.com/robertpniower/happy_bday.git'
        IMAGE_NAME = 'mirna-bday-app'
        CONTAINER_NAME = 'mirna-app'
        PORT_MAP = '3001:80' // Maps Pi Port 3001 to Container Port 80
    }

    stages {
        stage('Cleanup Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout from GitHub') {
            steps {
                // branch 'main' or 'master' depending on your repo
                git branch: 'master', url: "${REPO_URL}"
            }
        }

        stage('Build Docker Image') {
            steps {
                // 'sh' is used for Linux/Raspberry Pi
                sh "docker build -t ${IMAGE_NAME} ."
            }
        }

        stage('Deploy to Local Network') {
            steps {
                script {
                    // 1. Stop and remove the old container if it exists
                    // '|| true' prevents the pipeline from failing if the container isn't running
                    sh "docker stop ${CONTAINER_NAME} || true"
                    sh "docker rm ${CONTAINER_NAME} || true"

                    // 2. Run the new container
                    // Using --restart always ensures it survives a Pi reboot
                    sh "docker run -d --name ${CONTAINER_NAME} -p ${PORT_MAP} --restart always ${IMAGE_NAME}"
                }
            }
        }
    }

    post {
        success {
            echo "Success! App is live at http://mirna.pniower.home.arpa"
        }
        failure {
            echo "Deployment failed. Check 'docker ps' or Jenkins console output on the Pi."
        }
    }
}